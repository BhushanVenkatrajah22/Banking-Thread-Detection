datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   // Admin, SOC Analyst, Security Manager, Compliance Officer, Executive
  createdAt DateTime @default(now())
}

model Department {
  id         String     @id @default(uuid())
  name       String     @unique
  riskScore  Float      @default(0.0)
  trustScore Float      @default(100.0)
  employees  Employee[]
}

model Employee {
  id                  String               @id // e.g. EMP001
  name                String
  email               String               @unique
  role                String
  departmentId        String
  department          Department           @relation(fields: [departmentId], references: [id])
  status              String               // online, offline
  baselineStart       String               // e.g. "09:00"
  baselineEnd         String               // e.g. "18:00"
  currentStart        String
  currentEnd          String
  driftScore          Float
  trustScore          Float
  predictionRisk      Float
  aiTwinSummary       String
  anomaliesCount      Int                  @default(0)
  activities          EmployeeActivity[]
  twinProfile         DigitalTwinProfile?
  predictions         RiskPrediction[]
  cases               InvestigationReport[]
}

model EmployeeActivity {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  timestamp   DateTime
  category    String   // login, database, file, usb, privilege, network
  description String
  severity    String   // low, medium, high
  anomaly     Boolean
}

model DigitalTwinProfile {
  id             String   @id @default(uuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  behaviorDNA    String   // Serialized JSON array of strings
  weeklyPattern  String   // Serialized JSON array of numbers
  monthlyPattern String   // Serialized JSON array of numbers
}

model RiskPrediction {
  id            String   @id @default(uuid()) // PRD001
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  probability   Float
  confidence    Float
  timeWindow    String
  attackType    String
  businessImpact String   // Critical, High, Medium, Low
  explainableAI String   // Serialized JSON array of reasons
  status        String   // active, investigating, resolved, dismissed
  detectedAt    DateTime @default(now())
}

model InvestigationReport {
  id            String   @id // CASE-2026-001
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  severity      String   // high, medium, low
  status        String   // open, under_review, resolved
  assignedTo    String
  createdAt     DateTime @default(now())
  description   String
  evidence      String   // Serialized JSON array of evidence strings
  aiExplanation String
  notes         String   // Serialized JSON array of analyst notes strings
}

model ThreatAlert {
  id          String   @id @default(uuid())
  title       String
  description String
  severity    String   // high, medium, low
  time        String
  unread      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model AIRecommendation {
  id        String @id @default(uuid())
  target    String
  finding   String
  action    String
  severity  String @default("high")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String
  timestamp DateTime @default(now())
  details   String
}
